<?xml version="1.0" encoding="utf-8"?>
<!-- Wear OS / phone: allow HTTP to LAN backend (Express on PC). Required in addition to usesCleartextTraffic on some builds. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
