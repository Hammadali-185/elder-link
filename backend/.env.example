# MongoDB Atlas Connection String
# Replace with your own MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database-name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/elderlink?retryWrites=true&w=majority

# Server Port (optional, defaults to 5000)
PORT=5000
