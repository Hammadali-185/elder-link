rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Staff: each user writes only their own profile. Reads are open so the local
    // admin session (admin/admin, no Firebase Auth) can list nurses in Firestore.
    // Tighten for production (e.g. custom claims + match on role) if this is a concern.
    match /staff_profiles/{uid} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
